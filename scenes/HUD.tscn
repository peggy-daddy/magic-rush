[gd_scene load_steps=5 format=3 uid="uid://hud_overlay"]

[ext_resource type="Script" path="res://scripts/HUD.gd" id="1_hudscript"]
[ext_resource type="Texture2D" path="res://assets/ui/Stage/Cristalblue.png" id="2_cristalblue"]
[ext_resource type="Texture2D" path="res://assets/ui/Stage/Cristalorange.png" id="3_cristalorange"]
[ext_resource type="Texture2D" path="res://assets/ui/Stage/Cristalred.png" id="4_cristalred"]

[sub_resource type="StyleBoxFlat" id="1_hudbg"]
bg_color = Color(0.05, 0.04, 0.10, 0.82)
border_width_bottom = 2
border_color = Color(0.55, 0.42, 0.12, 0.9)

[node name="HUD" type="CanvasLayer"]
layer = 5
script = ExtResource("1_hudscript")

; Full-width anchor strip at the top of the screen
[node name="HUDPanel" type="PanelContainer" parent="."]
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 0.0
offset_bottom = 52.0
theme_override_styles/panel = SubResource("1_hudbg")

[node name="HBoxContainer" type="HBoxContainer" parent="HUDPanel"]
layout_mode = 2
theme_override_constants/separation = 0

; ── LEFT SECTION: Chi Bar (30% of HUD width) ─────────────────────────────

[node name="ChiSection" type="HBoxContainer" parent="HUDPanel/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 0.3
theme_override_constants/separation = 6

[node name="ChiMargin" type="MarginContainer" parent="HUDPanel/HBoxContainer/ChiSection"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 4
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 11
theme_override_constants/margin_right = 6
theme_override_constants/margin_bottom = 11

[node name="ChiHBox" type="HBoxContainer" parent="HUDPanel/HBoxContainer/ChiSection/ChiMargin"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 4
theme_override_constants/separation = 4

[node name="CrystalIcon" type="TextureRect" parent="HUDPanel/HBoxContainer/ChiSection/ChiMargin/ChiHBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 4
custom_minimum_size = Vector2(30, 30)
texture = ExtResource("2_cristalblue")
expand_mode = 1
stretch_mode = 5

[node name="ChiLabelMin" type="Label" parent="HUDPanel/HBoxContainer/ChiSection/ChiMargin/ChiHBox"]
layout_mode = 2
size_flags_vertical = 4
text = "0"
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.75, 0.75, 0.75, 1.0)

[node name="ChiBar" type="TextureProgressBar" parent="HUDPanel/HBoxContainer/ChiSection/ChiMargin/ChiHBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 4
custom_minimum_size = Vector2(250, 30)
min_value = 0.0
max_value = 100.0
value = 0.0
nine_patch_stretch = true
tint_under = Color(0.1, 0.08, 0.06, 0.8)
tint_progress = Color(0.9, 0.15, 0.15, 1.0)
tint_over = Color(0.4, 0.35, 0.18, 0.0)

[node name="ChiLabelMax" type="Label" parent="HUDPanel/HBoxContainer/ChiSection/ChiMargin/ChiHBox"]
layout_mode = 2
size_flags_vertical = 4
text = "100"
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.75, 0.75, 0.75, 1.0)

; ── CENTER SECTION: Title + Score Display ─────────────────────────────────

[node name="CenterSection" type="CenterContainer" parent="HUDPanel/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 0.4

[node name="CenterVBox" type="VBoxContainer" parent="HUDPanel/HBoxContainer/CenterSection"]
layout_mode = 2
theme_override_constants/separation = 1

[node name="TitleLabel" type="Label" parent="HUDPanel/HBoxContainer/CenterSection/CenterVBox"]
