custom_minimum_size = Vector2(32, 32)
focus_mode = 2
text = "SFX"
theme_override_font_sizes/font_size = 11
tooltip_text = "Toggle SFX"

[node name="RightPad" type="MarginContainer" parent="HUDPanel/HBoxContainer/TimerSection"]
layout_mode = 2
theme_override_constants/margin_right = 8

; ── RULES PANEL (shown when ? button pressed, works while paused) ────────────

[node name="RulesPanel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -420.0
offset_top = -340.0
offset_right = 420.0
offset_bottom = 340.0
visible = false
z_index = 20
process_mode = 4

[node name="RulesPanelMargin" type="MarginContainer" parent="RulesPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 18.0
offset_top = 18.0
offset_right = -18.0
offset_bottom = -18.0
theme_override_constants/separation = 10

[node name="RulesVBox" type="VBoxContainer" parent="RulesPanel/RulesPanelMargin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="RulesTitle" type="Label" parent="RulesPanel/RulesPanelMargin/RulesVBox"]
layout_mode = 2
text = "Magic Rush — How to Play  (click anywhere to close)"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(1.0, 0.843, 0.0, 1.0)

[node name="RulesText" type="Label" parent="RulesPanel/RulesPanelMargin/RulesVBox"]
layout_mode = 2
text = "GOAL: Fill your Magic Meter to 100 for PERFECT VICTORY!
      Survive 3 minutes without the meter hitting zero.

MAGIC METER:
  +10 for each NPC order delivered (max 8 orders each)
  +40 for silencing the Demon Baby
  -2 per second when Demon Baby is awake

SANCTUARY:
  Drag items from drawers to Slot A or B
  Press CRAFT to combine -> item goes to Inventory
  Drawers refill after 5 seconds

LIVING ROOM:
  Drag items from Inventory to NPCs
  Click ! above NPC to see their request
  4 NPCs, each has 8 orders to fulfill

DEMON BABY (center):
  Wakes every 60 seconds -- drains your Magic!
  Craft Heart Seal (Obsidian+Crystal) and deliver to Baby
  Obsidian = Water+Paper, Crystal = Candle+Potion

3 ENDINGS:
  PERFECT: Reach 100 Magic before time runs out!
  NORMAL:  Survive 3 min with some Magic remaining
  FAIL:    Magic hits zero -- you lose instantly!

Controls: Left-click drag | SPACE pause | ESC quit | ENTER replay"
theme_override_font_sizes/font_size = 13
autowrap_mode = 3

[node name="CloseRulesBtn" type="Button" parent="RulesPanel"]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 0
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 0.0
anchor_bottom = 0.0
offset_left = 380.0
offset_top = 8.0
offset_right = 420.0
offset_bottom = 40.0
z_index = 20
text = "X"
theme_override_font_sizes/font_size = 16

