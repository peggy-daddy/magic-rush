theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.843, 0.0, 1.0)

[node name="HTPScroll" type="ScrollContainer" parent="HowToPlayPanel/VBox"]
layout_mode = 2
